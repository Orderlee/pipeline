# .agent/ — track shared skill/orchestration infra, ignore drafts
.agent/*
!.agent/skill/
!.agent/skill/**
!.agent/decisions.log
# re-ignore Python bytecode under skill scripts (caught by the .agent/skill/** unignore above)
.agent/skill/**/__pycache__/
.agent/skill/**/*.py[cod]

# .claude/ — track team-shared agent config, ignore per-user state and runtime data
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/agents/**
# (the following stay ignored under the .claude/* pattern above; listed for clarity)
# .claude/settings.local.json   — contains LINEAR_API_KEY, per-user permissions
# .claude/agent-log.jsonl       — runtime hook output, append-only session activity

