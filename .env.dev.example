# =====================================================
# 로컬 개발 환경 설정 (.env.dev)
# 이 파일을 .env.dev로 복사 후 로컬 경로에 맞게 수정
# 사용법: cp .env.dev.example .env.dev
# =====================================================

# === MinIO (로컬 Docker) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === PostgreSQL ===
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5432

# === Dagster ===
DAGSTER_PORT=3030

# === 로컬 incoming/archive 경로 (필요 시 수정) ===
# Docker compose에서 자동으로 ./data_dev/incoming, ./data_dev/archive 사용
# 별도 경로를 쓰려면 아래 주석 해제
# DEV_INCOMING_PATH=/path/to/local/incoming
# DEV_ARCHIVE_PATH=/path/to/local/archive

# === Gemini / Vertex AI (로컬 테스트 시) ===
# GEMINI_PROJECT=
# GEMINI_LOCATION=
# GEMINI_SERVICE_ACCOUNT_JSON=

# === MotherDuck (로컬에서는 보통 비활성화) ===
MOTHERDUCK_SYNC_ENABLED=false
