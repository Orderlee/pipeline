# =====================================================
# Test runtime for dev branch
# dev = test, main = production
# =====================================================

PIPELINE_RUNTIME_ENV=test
COMPOSE_PROJECT_NAME=pipeline-test

# === UI / external service reference ===
DAGSTER_PORT=3031
DAGSTER_UI_URL=http://10.0.0.10:3031/
MINIO_CONSOLE_URL=http://10.0.0.51:9003/

# === DuckDB / MinIO runtime endpoint ===
DATAOPS_DUCKDB_PATH=/data/staging.duckdb
MINIO_ENDPOINT=http://10.0.0.51:9002
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# === Optional local infra ports (unused in normal test deploy) ===
MINIO_API_PORT=19002
MINIO_CONSOLE_PORT=19003
POSTGRES_PORT=15432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# === DB backend (staging default — single PG, no dual-write) ===
# 모든 write/read 가 PostgreSQL 단일 backend 로 진행되어 dual-write 병목 0.
# DuckDB ad-hoc 분석은 sensor_db.open_sensor_read_connection() 가
# in-memory DuckDB + ATTACH PG (READ_ONLY) 로 처리해 PG 데이터를 columnar 로 read.
# dual-write 가 필요한 환경이면 호스트 보존 .env.test 에서
# DATAOPS_DB_BACKEND=dual_pg_primary 로 override (mirror DuckDB 까지 동시 write).
DATAOPS_DB_BACKEND=postgres
DATAOPS_POSTGRES_DSN=postgresql://airflow:airflow@postgres:5432/vlm_pipeline_staging

# postgres image override — pgduckdb 로 swap 하여 PG 안에서 DuckDB 엔진 사용
# (CREATE EXTENSION pg_duckdb 후 read_parquet / S3 / Iceberg 등 가능).
# postgres_data volume 보존 → schema/데이터 손실 없음.
POSTGRES_IMAGE=pgduckdb/pgduckdb:15-v1.1.1
# pg_duckdb extension 은 PG 부팅 시 shared_preload_libraries 에 로드되어야
# CREATE EXTENSION 가능. compose 의 postgres command 에서 이 변수를 사용.
POSTGRES_PRELOAD_LIBS=pg_duckdb

# === Label Studio / cross-sync ===
LS_URL=http://labelstudio:8080
LS_MINIO_ENDPOINT=http://10.0.0.51:9000

# === Unified container paths ===
INCOMING_DIR=/nas/incoming
ARCHIVE_DIR=/nas/archive
ARCHIVE_PENDING_DIR=/nas/archive_pending
MANIFEST_DIR=/nas/incoming/.manifests
DATASET_PREFIX=mvp-v0.1

# === Host bind mounts: reuse existing staging data plane ===
DATASETS_HOST_PATH=/home/user/mou/nas_192tb/datasets
PROJECTS_HOST_PATH=/home/user/mou/nas_192tb/datasets/projects
ARCHIVE_HOST_PATH=/home/user/mou/staging/archive
INCOMING_HOST_PATH=/home/user/mou/staging/incoming
GCLOUD_CONFIG_HOST_PATH=/home/user/.config/gcloud

# === Runtime data / dagster state ===
DAGSTER_HOME_HOST_PATH=./app/dagster_home
DOCKER_DATA_HOST_PATH=./data
DATAOPS_ASSET_PATH_PREFIX_FROM=/home/user/mou/nas_192tb;/home/user/mou/staging/archive;/home/user/mou/staging/incoming
DATAOPS_ASSET_PATH_PREFIX_TO=/nas

# === Agent polling (test agent exposes /api/production/* paths) ===
PROD_AGENT_POLLING_ENABLED=true
PROD_AGENT_BASE_URL=http://host.docker.internal:8081
PROD_AGENT_POLL_LIMIT=20
PROD_AGENT_CONNECT_TIMEOUT_SEC=3
PROD_AGENT_READ_TIMEOUT_SEC=10
PROD_AGENT_SENSOR_INTERVAL_SEC=30

# === Sensors / guards ===
AUTO_BOOTSTRAP_SENSOR_INTERVAL_SEC=30
AUTO_BOOTSTRAP_STABLE_CYCLES=1
AUTO_BOOTSTRAP_STABLE_AGE_SEC=15
MANIFEST_SCAN_TIMEOUT_SEC=90
NETWORK_MOUNT_PROBE_TIMEOUT_SEC=8
NETWORK_MOUNT_PROBE_RETRIES=2
NETWORK_MOUNT_PROBE_RETRY_DELAY_MS=400
AUTO_BOOTSTRAP_LIST_TIMEOUT_SEC=60
AUTO_BOOTSTRAP_LIST_RETRIES=3
AUTO_BOOTSTRAP_LIST_RETRY_DELAY_MS=500
AUTO_BOOTSTRAP_UNIT_SCAN_TIMEOUT_SEC=180
AUTO_BOOTSTRAP_SKIP_ON_PARTIAL_SCAN=true
AUTO_BOOTSTRAP_DISCOVERY_MAX_TOP_ENTRIES=20
# `.tmp rename` 패턴으로 완료 신호 대체 — _DONE marker 불필요.
AUTO_BOOTSTRAP_REQUIRE_DONE_MARKER=false
DAGSTER_SENSOR_GRPC_TIMEOUT_SECONDS=300
INCOMING_SENSOR_MAX_IN_FLIGHT_RUNS=2
INCOMING_SENSOR_MAX_NEW_RUN_REQUESTS_PER_TICK=2
STUCK_RUN_GUARD_ENABLED=true
STUCK_RUN_GUARD_INTERVAL_SEC=120
STUCK_RUN_GUARD_TIMEOUT_SEC=10800
STUCK_RUN_GUARD_ORPHANED_RUN_TIMEOUT_SEC=900
STUCK_RUN_GUARD_MAX_CANCELS_PER_TICK=1
STUCK_RUN_GUARD_AUTO_REQUEUE_ENABLED=true
STUCK_RUN_GUARD_MAX_REQUEUES_PER_TICK=1
STUCK_RUN_GUARD_TARGET_JOBS=mvp_stage_job,ingest_job,dispatch_stage_job,motherduck_sync_job
MOTHERDUCK_SENSOR_INTERVAL_SEC=60
MOTHERDUCK_SENSOR_SKIP_DURING_DUCKDB_WRITER=true
GCS_STALL_SECONDS=1200
GCS_MAX_RESTARTS=5
GCS_ZERO_BYTE_RETRIES=3
INGEST_DEFER_VIDEO_ENV_CLASSIFICATION=true
INGEST_PREMOVE_ARCHIVE=false
INGEST_UPLOAD_WORKERS=8

# === Dispatch webhook ===
DISPATCH_WEBHOOK_PORT=8091
DISPATCH_WEBHOOK_SECRET=

# === MotherDuck / optional integrations ===
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB=
MOTHERDUCK_SYNC_ENABLED=false
MOTHERDUCK_SYNC_DRY_RUN=true
MOTHERDUCK_SHARE_UPDATE=
MOTHERDUCK_SYNC_TIMEOUT_SEC=

# === Gemini / Vertex AI ===
GEMINI_PROJECT=
GEMINI_LOCATION=
GEMINI_GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_SERVICE_ACCOUNT_JSON=
GEMINI_MAX_WORKERS=5
GEMINI_CHUNK_MAX_WORKERS=3

# === Feature toggles ===
ENABLE_MANUAL_LABEL_IMPORT=true
ENABLE_YOLO_DETECTION=true
ENABLE_SAM3_DETECTION=true
YOLO_DEFAULT_CLASSES=person,car,truck,bus,motorcycle,bicycle,fire,smoke,flame,cigarette,smoking,knife,gun,bat,baseball bat,sword,dagger,bag,backpack,suitcase,helmet,safety vest,hard hat,traffic cone,barricade,dog,cat

# =====================================================
# Container UID / 호스트 bind mount 경로 (git 작업트리 밖으로 이동 권장)
#   DOCKER_USER 기본값 0:0 (root). 호스트 user 계정 UID/GID로 돌리려면 "1000:1000" 설정.
#   *_HOST_PATH 미설정 시 기본값(repo 내 ./app/..., ./data_dev/...)을 사용해 기존 동작 유지.
#   migration 스크립트: scripts/migrate_docker_runtime_outside_repo.sh
# =====================================================
# DOCKER_USER=1000:1000
# DEV_DAGSTER_HOME_HOST_PATH=/home/user/vlm-pipeline/dev/dagster_home
# DEV_DATA_HOST_PATH=/home/user/vlm-pipeline/dev/data

# =====================================================
# GenAI Studio (Phase 3+) — staging
#   - 4 엔진 어댑터 키. 빈칸 시 KlingAdapter mocking 모드 동작.
#   - 사용자가 채운 뒤 staging compose `--profile genai` 재시작.
# =====================================================
GENAI_PORT=8088
GENAI_ENGINES_ENABLED=kling,higgsfield,veo,nanobanana,gpt_image
GENAI_BASIC_AUTH_USER=
GENAI_BASIC_AUTH_PASS=
# 사내망에서 인증 우회 명시 opt-in. true 시에만 우회. 미설정/false 면 503 응답.
GENAI_AUTH_DISABLED=
GENAI_MAX_BYTES_PER_FILE=52428800
GENAI_MAX_FILES_PER_BATCH=20
GENAI_POLL_INTERVAL_SECONDS=30

# Kling AI (image2video) — JWT(AccessKey iss + SecretKey sign)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE=https://api.klingai.com
KLING_SUBMIT_TIMEOUT=60
KLING_POLL_TIMEOUT=30
KLING_DOWNLOAD_TIMEOUT=300

# Higgsfield via fal.ai (Phase 4)
FAL_KEY=

# OpenAI (gpt-image-1, Phase 4)
OPENAI_API_KEY=

# Nanobanana (Gemini 2.5 Flash Image) — Vertex SA 재사용 (Phase 4)
# GEMINI_GOOGLE_APPLICATION_CREDENTIALS 위 항목 그대로 사용

# Internal API token — Dagster genai_poll_sensor 가 docker/genai 컨테이너 호출 시 사용.
# 미설정 시 sensor 가 SkipReason 으로 비활성. 운영자가 임의 secret 으로 채울 것.
GENAI_INTERNAL_TOKEN=
GENAI_INTERNAL_BASE=http://genai:8088
GENAI_POLL_BATCH=20

# Phase 5 — quota / rate-limit. 0 = off (사내망 가정 시 default off).
GENAI_RATE_LIMIT_PER_MIN=0
GENAI_DAILY_BATCH_LIMIT=0
GENAI_DAILY_BYTES_LIMIT=0

# Kling Pro 플랜 — model_name dropdown 후보. CSV. 미설정 시 KlingAdapter.DEFAULT_MODELS 사용.
# 기본 default: kling-video-o1 (Pro plan 가용). 운영자가 본인 plan 기준으로 조정 가능.
KLING_AVAILABLE_MODELS=
KLING_MODE=pro
KLING_DURATION=5

# Veo (Vertex AI image2video) — Vertex SA 재사용
VEO_MODEL_NAME=veo-3.1-generate-001
VEO_AVAILABLE_MODELS=
VEO_ASPECT_RATIO=16:9
VEO_OUTPUT_GCS_URI=

# Veo duration — 가용 (4/6/8s for 3.1, 8s only for 3.0)
VEO_DURATION_SECONDS=8
VEO_AVAILABLE_DURATIONS=4,6,8
