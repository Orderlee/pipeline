# =====================================================
# Staging 환경 — 운영(.env)과 분리된 DuckDB + MinIO
# =====================================================

# === DuckDB (staging 전용) ===
DATAOPS_DUCKDB_PATH=/data/staging.duckdb

# === MinIO (NAS staging 인스턴스, 포트 9002) ===
MINIO_ENDPOINT=http://172.168.47.36:9002
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# === Staging 모드 활성화 ===
IS_STAGING=true

# === NAS 마운트 (staging 경로) ===
INCOMING_DIR=/nas/staging/incoming
ARCHIVE_DIR=/nas/staging/archive
MANIFEST_DIR=/nas/staging/incoming/.manifests
DATASET_PREFIX=

# === NAS 마운트 (호스트 경로: staging CIFS) ===
DATASETS_HOST_PATH=
PROJECTS_HOST_PATH=
ARCHIVE_HOST_PATH=
INCOMING_HOST_PATH=

# === Sensor / Guard ===
AUTO_BOOTSTRAP_SENSOR_INTERVAL_SEC=30
AUTO_BOOTSTRAP_STABLE_CYCLES=1
AUTO_BOOTSTRAP_STABLE_AGE_SEC=15
MANIFEST_SCAN_TIMEOUT_SEC=90
NETWORK_MOUNT_PROBE_TIMEOUT_SEC=8
NETWORK_MOUNT_PROBE_RETRIES=2
NETWORK_MOUNT_PROBE_RETRY_DELAY_MS=400
AUTO_BOOTSTRAP_LIST_TIMEOUT_SEC=60
AUTO_BOOTSTRAP_LIST_RETRIES=3
AUTO_BOOTSTRAP_LIST_RETRY_DELAY_MS=500
AUTO_BOOTSTRAP_UNIT_SCAN_TIMEOUT_SEC=180
AUTO_BOOTSTRAP_SKIP_ON_PARTIAL_SCAN=true
# NAS 지연 시 discovery 틱당 상위 디렉터리 수 (0=무제한). 운영과 동일 권장: 20
AUTO_BOOTSTRAP_DISCOVERY_MAX_TOP_ENTRIES=20
# 센서 gRPC 타임아웃(초). NAS 지연 시 300 권장
DAGSTER_SENSOR_GRPC_TIMEOUT_SECONDS=300
INCOMING_SENSOR_MAX_IN_FLIGHT_RUNS=2
INCOMING_SENSOR_MAX_NEW_RUN_REQUESTS_PER_TICK=2
STUCK_RUN_GUARD_ENABLED=true
STUCK_RUN_GUARD_INTERVAL_SEC=120
STUCK_RUN_GUARD_TIMEOUT_SEC=10800
STUCK_RUN_GUARD_ORPHANED_RUN_TIMEOUT_SEC=900
STUCK_RUN_GUARD_MAX_CANCELS_PER_TICK=1
STUCK_RUN_GUARD_AUTO_REQUEUE_ENABLED=true
STUCK_RUN_GUARD_MAX_REQUEUES_PER_TICK=1
STUCK_RUN_GUARD_TARGET_JOBS=mvp_stage_job,ingest_job,dispatch_stage_job,motherduck_sync_job
MOTHERDUCK_SENSOR_INTERVAL_SEC=60
MOTHERDUCK_SENSOR_SKIP_DURING_DUCKDB_WRITER=true
STAGING_AGENT_POLLING_ENABLED=true
STAGING_AGENT_BASE_URL=http://host.docker.internal:8080
STAGING_AGENT_POLL_LIMIT=20
STAGING_AGENT_CONNECT_TIMEOUT_SEC=3
STAGING_AGENT_READ_TIMEOUT_SEC=10
STAGING_AGENT_SENSOR_INTERVAL_SEC=30
GCS_STALL_SECONDS=1200
GCS_MAX_RESTARTS=5
GCS_ZERO_BYTE_RETRIES=3
INGEST_DEFER_VIDEO_ENV_CLASSIFICATION=true
INGEST_PREMOVE_ARCHIVE=false

# === Canonical Path 정책 ===
DATAOPS_ASSET_PATH_PREFIX_FROM=
DATAOPS_ASSET_PATH_PREFIX_TO=

# === MotherDuck (staging에서는 비활성화) ===
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB=
MOTHERDUCK_SYNC_ENABLED=false
MOTHERDUCK_SYNC_DRY_RUN=true
MOTHERDUCK_SHARE_UPDATE=
MOTHERDUCK_SYNC_TIMEOUT_SEC=
GEMINI_PROJECT=
GEMINI_LOCATION=
GEMINI_GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_SERVICE_ACCOUNT_JSON=
ENABLE_MANUAL_LABEL_IMPORT=true
ENABLE_YOLO_DETECTION=true
YOLO_DEFAULT_CLASSES=

# ===== Gemini / Vertex AI =====
GEMINI_PROJECT=gmail-361002
GEMINI_LOCATION=us-central1
GEMINI_GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gmail-361002-cbcf95afec4a.json
GEMINI_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"gmail-361002","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"gemini-api@gmail-361002.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/gemini-api%40gmail-361002.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
ENABLE_MANUAL_LABEL_IMPORT=true
ENABLE_YOLO_DETECTION=true
YOLO_DEFAULT_CLASSES=person,car,truck,bus,motorcycle,bicycle,fire,smoke,flame,knife,gun,bag,backpack,suitcase,helmet,safety vest,hard hat,traffic cone,barricade,dog,cat
