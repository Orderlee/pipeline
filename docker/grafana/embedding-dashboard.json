          "rawQuery": true,
          "rawSql": "SELECT\n  relname AS object_name,\n  CASE relkind WHEN 'r' THEN 'table' WHEN 'i' THEN 'index' ELSE relkind::text END AS kind,\n  pg_relation_size(oid) AS size_bytes,\n  pg_size_pretty(pg_relation_size(oid)) AS size_pretty\nFROM pg_class\nWHERE relname LIKE 'image_embeddings%'\nORDER BY relname",
