        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  'frame backlog' AS backlog_type,\n  COUNT(*) AS count\nFROM image_metadata im\nWHERE im.image_bucket IS NOT NULL\n  AND im.image_key IS NOT NULL\n  AND NOT EXISTS (\n    SELECT 1 FROM image_embeddings e\n    WHERE e.entity_type = 'frame'\n      AND e.entity_id = im.image_id\n  )\nUNION ALL\nSELECT\n  'caption backlog' AS backlog_type,\n  COUNT(*) AS count\nFROM labels l\nWHERE l.caption_text IS NOT NULL\n  AND l.caption_text <> ''\n  AND NOT EXISTS (\n    SELECT 1 FROM image_embeddings e\n    WHERE e.entity_type = 'caption'\n      AND e.entity_id = l.label_id\n  )\nORDER BY backlog_type",
          "refId": "A"
        }
      ],
      "title": "Unembedded Backlog (frame + caption)",
      "type": "table"
    },
