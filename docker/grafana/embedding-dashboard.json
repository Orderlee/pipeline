          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_TRUNC('day', created_at) AS time,\n  entity_type,\n  COUNT(*) AS count\nFROM image_embeddings\nWHERE created_at >= NOW() - INTERVAL '30 days'\nGROUP BY DATE_TRUNC('day', created_at), entity_type\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Daily Embeddings Ingested (last 30 days)",
