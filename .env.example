# === DuckDB ===
DATAOPS_DUCKDB_PATH=/data/pipeline.duckdb

# === MinIO (Docker 내부 네트워크) ===
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# === NAS 마운트 (컨테이너 내부 경로) ===
INCOMING_DIR=/nas/incoming
ARCHIVE_DIR=/nas/archive
MANIFEST_DIR=/nas/incoming/.manifests
DATASET_PREFIX=mvp-v0.1

# === NAS 마운트 (호스트 경로: CIFS 통합) ===
DATASETS_HOST_PATH=/home/pia/mou/nas_192tb/datasets
PROJECTS_HOST_PATH=/home/pia/mou/nas_192tb/datasets/projects
ARCHIVE_HOST_PATH=/home/pia/mou/archive
INCOMING_HOST_PATH=/home/pia/mou/incoming

AUTO_BOOTSTRAP_STABLE_CYCLES=2
AUTO_BOOTSTRAP_STABLE_AGE_SEC=120
MANIFEST_SCAN_TIMEOUT_SEC=90
NETWORK_MOUNT_PROBE_TIMEOUT_SEC=8
NETWORK_MOUNT_PROBE_RETRIES=2
NETWORK_MOUNT_PROBE_RETRY_DELAY_MS=400
AUTO_BOOTSTRAP_LIST_TIMEOUT_SEC=60
AUTO_BOOTSTRAP_LIST_RETRIES=3
AUTO_BOOTSTRAP_LIST_RETRY_DELAY_MS=500
AUTO_BOOTSTRAP_UNIT_SCAN_TIMEOUT_SEC=180
AUTO_BOOTSTRAP_SKIP_ON_PARTIAL_SCAN=true
DAGSTER_SENSOR_GRPC_TIMEOUT_SECONDS=180

# === Canonical Path 정책 ===
DATAOPS_ASSET_PATH_PREFIX_FROM=/home/pia/mou/nas_192tb;/home/pia/mou/archive;/home/pia/mou/incoming
DATAOPS_ASSET_PATH_PREFIX_TO=/nas

# === MotherDuck Sync (optional) ===
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB=mvp_db_yw
MOTHERDUCK_SYNC_ENABLED=false
MOTHERDUCK_SYNC_DRY_RUN=false
MOTHERDUCK_SHARE_UPDATE=MANUAL
MOTHERDUCK_SYNC_TIMEOUT_SEC=600
